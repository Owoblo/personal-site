# Environment Variables for Cloudflare Pages
# Copy these to your Pages project under Settings > Variables and Secrets

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Admin Password - Set your own secure password
ADMIN_PASSWORD=your-secure-password-here

# GitHub Personal Access Token - Get from https://github.com/settings/tokens
# Needs 'repo' scope to commit posts.json
GITHUB_TOKEN=ghp_your-token-here

# GitHub Repository - Format: username/repo-name
GITHUB_REPO=Owoblo/personal-site

# Optional: Instagram publishing
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token-here
INSTAGRAM_BUSINESS_ID=your-instagram-business-id-here
